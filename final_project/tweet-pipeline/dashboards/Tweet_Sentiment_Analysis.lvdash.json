{
  "datasets": [
    {
      "name": "d09acb14",
      "displayName": "total_tweets",
      "queryLines": [
        "SELECT COUNT(*) AS total_tweets FROM workspace.default.tweets_bronze"
      ]
    },
    {
      "name": "9c19ee8b",
      "displayName": "tweets_with_mentions",
      "queryLines": [
        "SELECT COUNT(*) AS tweets_with_mentions FROM workspace.default.tweets_silver WHERE mention IS NOT NULL"
      ]
    },
    {
      "name": "b86f411f",
      "displayName": "tweets_without_mentions",
      "queryLines": [
        "SELECT COUNT(*) AS tweets_without_mentions FROM workspace.default.tweets_silver WHERE mention IS NULL"
      ]
    },
    {
      "name": "f10fd22e",
      "displayName": "top_10_users",
      "queryLines": [
        "SELECT user, COUNT(*) AS tweet_count FROM workspace.default.tweets_bronze GROUP BY user ORDER BY tweet_count DESC LIMIT 10"
      ]
    },
    {
      "name": "6602383c",
      "displayName": "top_10_positive",
      "queryLines": [
        "SELECT mention, positive FROM workspace.default.gold_tweet_aggregations ORDER BY positive DESC LIMIT 10"
      ]
    },
    {
      "name": "d234e607",
      "displayName": "top_10_negative",
      "queryLines": [
        "SELECT mention, negative FROM workspace.default.gold_tweet_aggregations ORDER BY negative DESC LIMIT 10"
      ]
    },
    {
      "name": "f21871ce",
      "displayName": "users_with_sentiment_breakdown",
      "queryLines": [
        "SELECT user, \r\n",
        "    COUNT(*) AS total_tweets,\r\n",
        "    SUM(CASE WHEN sentiment = '4' THEN 1 ELSE 0 END) AS positive_tweets,\r\n",
        "    SUM(CASE WHEN sentiment = '0' THEN 1 ELSE 0 END) AS negative_tweets\r\n",
        "FROM workspace.default.tweets_bronze\r\n",
        "GROUP BY user\r\n",
        "ORDER BY total_tweets DESC\r\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "80eca708",
      "displayName": "sentiment_overtime",
      "queryLines": [
        "SELECT DATE_TRUNC('day', timestamp) AS day, \r\n",
        "    predicted_sentiment, COUNT(*) AS count\r\n",
        "FROM workspace.default.tweets_gold\r\n",
        "WHERE timestamp IS NOT NULL\r\n",
        "GROUP BY day, predicted_sentiment\r\n",
        "ORDER BY day"
      ]
    },
    {
      "name": "049a553b",
      "displayName": "confidence_over_sentiment",
      "queryLines": [
        "SELECT predicted_sentiment, ROUND(AVG(predicted_score), 2) AS avg_confidence\r\n",
        "FROM workspace.default.tweets_gold\r\n",
        "GROUP BY predicted_sentiment"
      ]
    }
  ],
