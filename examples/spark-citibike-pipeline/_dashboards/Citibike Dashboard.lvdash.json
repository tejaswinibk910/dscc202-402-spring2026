{
  "datasets": [
    {
      "name": "station_connections",
      "displayName": "Station Connections (Map)",
      "queryLines": [
        "SELECT\n",
        "  other_station,\n",
        "  lat,\n",
        "  lng,\n",
        "  departure_count,\n",
        "  arrival_count,\n",
        "  total_trips,\n",
        "  net_flow,\n",
        "  t_lat,\n",
        "  t_lng,\n",
        "  target_station\n",
        "FROM workspace.default.gold_station_connections\n",
        "ORDER BY total_trips DESC"
      ]
    },
    {
      "name": "hourly_counts",
      "displayName": "Hourly Counts",
      "queryLines": [
        "SELECT\n",
        "  day_of_week,\n",
        "  day_label,\n",
        "  hour,\n",
        "  departure_count,\n",
        "  arrival_count,\n",
        "  total_count,\n",
        "  target_station\n",
        "FROM workspace.default.gold_hourly_counts\n",
        "ORDER BY day_of_week, hour"
      ]
    },
    {
      "name": "weekly_counts",
      "displayName": "Weekly Counts",
      "queryLines": [
        "SELECT\n",
        "  week_start,\n",
        "  departures,\n",
        "  arrivals,\n",
        "  total_trips,\n",
        "  target_station\n",
        "FROM workspace.default.gold_weekly_counts\n",
        "ORDER BY week_start"
      ]
    }
  ],
  "pages": [
    {
      "name": "cb1a2e3f",
      "displayName": "Citi Bike Station Overview",
      "layout": [
        {
          "widget": {
            "name": "a1b2c3d4",
            "multilineTextboxSpec": {
              "lines": [
                "## 🚲 Citi Bike NYC — Station Dashboard\n",
                "\n",
                "Trips **to** and **from** the configured target station, with hourly and weekly trends.\n",
                "\n",
                "Target station is controlled by the `target_station` parameter in `spark-pipeline.yml`."
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "e5f6a7b8",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "station_connections",
                  "fields": [
                    {
                      "name": "other_station",
                      "expression": "`other_station`"
                    },
                    {
                      "name": "departure_count",
                      "expression": "`departure_count`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Trips from Target Station by Destination",
                "showTitle": true
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "other_station",
                  "displayName": "Destination Station",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "departure_count",
                  "displayName": "Trip Count",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 6,
            "height": 8
          }
        },
        {
          "widget": {
            "name": "c9d0e1f2",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "weekly_counts",
                  "fields": [
                    {
                      "name": "monthly(week_start)",
                      "expression": "DATE_TRUNC(\"MONTH\", `week_start`)"
                    },
                    {
                      "name": "sum(departures)",
                      "expression": "SUM(`departures`)"
                    },
                    {
                      "name": "sum(arrivals)",
                      "expression": "SUM(`arrivals`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Weekly Departures & Arrivals",
                "showTitle": true
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "monthly(week_start)",
                  "scale": {
                    "type": "temporal"
                  }
                },
                "y": {
                  "scale": {
                    "type": "quantitative"
                  },
                  "fields": [
                    {
                      "fieldName": "sum(departures)"
                    },
                    {
                      "fieldName": "sum(arrivals)"
                    }
                  ]
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 10,
            "width": 6,
            "height": 5
          }
        },
        {
          "widget": {
            "name": "d3e4f5a6",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "hourly_counts",
                  "fields": [
                    {
                      "name": "hour",
                      "expression": "`hour`"
                    },
                    {
                      "name": "sum(departure_count)",
                      "expression": "SUM(`departure_count`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Departures by Hour & Day of Week",
                "showTitle": true
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "hour",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "y": {
                  "fieldName": "sum(departure_count)",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 15,
            "width": 3,
            "height": 5
          }
        },
        {
          "widget": {
            "name": "b7c8d9e0",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "hourly_counts",
                  "fields": [
                    {
                      "name": "hour",
                      "expression": "`hour`"
                    },
                    {
                      "name": "sum(arrival_count)",
                      "expression": "SUM(`arrival_count`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Arrivals by Hour & Day of Week",
                "showTitle": true
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "hour",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "y": {
                  "fieldName": "sum(arrival_count)",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            }
          },
          "position": {
            "x": 3,
            "y": 15,
            "width": 3,
            "height": 5
          }
        }
      ],
      "pageType": "PAGE_TYPE_CANVAS"
    }
  ],
  "uiSettings": {
    "theme": {
      "widgetHeaderAlignment": "ALIGNMENT_UNSPECIFIED"
    },
    "applyModeEnabled": false
  }
}
